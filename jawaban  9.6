handle = open('soal.txt', 'r')

baris_soal = handle.readlines()
handle.close()

for baris in baris_soal:
  baris = baris.strip()

  if baris == "":
    continue

  bagian = baris.split(" || ")
  soal = bagian[0]
  jawaban_benar = bagian[1]

  print(f"\n{soal}")

  jawaban_user = input("Jawab: ")

  if jawaban_user.lower() == jawaban_benar.lower():
    print("Jawaban benar!")
  else:
    print("Jawaban salah!")
